/**
 * @description Service class for Compliance Log management
 * Handles audit trail creation and compliance tracking for FINRA requirements
 * @author BlackRoad OS
 */
public with sharing class ComplianceService {

    // Log type constants
    public static final String LOG_TYPE_MEETING = 'Meeting';
    public static final String LOG_TYPE_PHONE_CALL = 'Phone Call';
    public static final String LOG_TYPE_EMAIL = 'Email';
    public static final String LOG_TYPE_DOCUMENT = 'Document Received';
    public static final String LOG_TYPE_SYSTEM = 'System Event';
    public static final String LOG_TYPE_TRADE = 'Trade Execution';
    public static final String LOG_TYPE_REVIEW = 'Portfolio Review';

    /**
     * @description Creates a compliance log entry
     * @param householdId The household this log relates to
     * @param logType The type of compliance event
     * @param description Description of the event
     * @param isAutoGenerated Whether this was system-generated
     * @return The created Compliance_Log__c record
     */
    public static Compliance_Log__c createLog(
        Id householdId,
        String logType,
        String description,
        Boolean isAutoGenerated
    ) {
        Compliance_Log__c log = new Compliance_Log__c(
            Household__c = householdId,
            Log_Type__c = logType,
            Description__c = description,
            Auto_Generated__c = isAutoGenerated != null ? isAutoGenerated : false
        );

        insert log;
        return log;
    }

    /**
     * @description Creates multiple compliance log entries in bulk
     * @param logs List of Compliance_Log__c records to insert
     */
    public static void createLogs(List<Compliance_Log__c> logs) {
        if (logs != null && !logs.isEmpty()) {
            insert logs;
        }
    }

    /**
     * @description Logs a client meeting
     * @param householdId The household ID
     * @param meetingNotes Notes from the meeting
     * @param attendees Who attended
     * @return The created log record
     */
    public static Compliance_Log__c logMeeting(
        Id householdId,
        String meetingNotes,
        String attendees
    ) {
        String description = 'CLIENT MEETING\n';
        description += 'Attendees: ' + (attendees != null ? attendees : 'Not specified') + '\n';
        description += 'Notes: ' + (meetingNotes != null ? meetingNotes : 'No notes recorded');

        return createLog(householdId, LOG_TYPE_MEETING, description, false);
    }

    /**
     * @description Logs a portfolio review completion
     * @param householdId The household ID
     * @param reviewType Type of review (Annual, Quarterly, Ad-hoc)
     * @param findings Key findings from review
     * @return The created log record
     */
    public static Compliance_Log__c logPortfolioReview(
        Id householdId,
        String reviewType,
        String findings
    ) {
        String description = 'PORTFOLIO REVIEW - ' + reviewType + '\n';
        description += 'Date: ' + Date.today().format() + '\n';
        description += 'Findings: ' + (findings != null ? findings : 'Review completed - no issues identified');

        return createLog(householdId, LOG_TYPE_REVIEW, description, false);
    }

    /**
     * @description Logs a trade execution for audit purposes
     * @param householdId The household ID
     * @param tradeDetails Details of the trade
     * @return The created log record
     */
    public static Compliance_Log__c logTradeExecution(
        Id householdId,
        String tradeDetails
    ) {
        String description = 'TRADE EXECUTED\n';
        description += 'Date/Time: ' + Datetime.now().format() + '\n';
        description += 'Details: ' + tradeDetails;

        return createLog(householdId, LOG_TYPE_TRADE, description, true);
    }

    /**
     * @description Gets compliance logs for a household within date range
     * @param householdId The household ID
     * @param startDate Start of date range
     * @param endDate End of date range
     * @return List of compliance logs
     */
    public static List<Compliance_Log__c> getLogsForHousehold(
        Id householdId,
        Date startDate,
        Date endDate
    ) {
        return [
            SELECT Id, Name, Log_Type__c, Description__c,
                   Auto_Generated__c, CreatedDate, CreatedById
            FROM Compliance_Log__c
            WHERE Household__c = :householdId
            AND CreatedDate >= :startDate
            AND CreatedDate <= :endDate
            WITH SECURITY_ENFORCED
            ORDER BY CreatedDate DESC
        ];
    }

    /**
     * @description Gets all logs for compliance audit report
     * @param startDate Start of audit period
     * @param endDate End of audit period
     * @return List of all compliance logs in period
     */
    public static List<Compliance_Log__c> getAuditReport(Date startDate, Date endDate) {
        return [
            SELECT Id, Name, Log_Type__c, Description__c,
                   Auto_Generated__c, CreatedDate, CreatedById,
                   Household__c, Household__r.Name
            FROM Compliance_Log__c
            WHERE CreatedDate >= :startDate
            AND CreatedDate <= :endDate
            WITH SECURITY_ENFORCED
            ORDER BY Household__c, CreatedDate DESC
        ];
    }

    /**
     * @description Checks if household has required documentation
     * @param householdId The household ID
     * @param requiredLogTypes List of required log types
     * @param withinDays Number of days to check
     * @return Map of log type to whether it exists
     */
    public static Map<String, Boolean> checkRequiredDocumentation(
        Id householdId,
        List<String> requiredLogTypes,
        Integer withinDays
    ) {
        Map<String, Boolean> results = new Map<String, Boolean>();
        Date cutoffDate = Date.today().addDays(-withinDays);

        // Initialize all as false
        for (String logType : requiredLogTypes) {
            results.put(logType, false);
        }

        // Query existing logs
        List<Compliance_Log__c> existingLogs = [
            SELECT Log_Type__c
            FROM Compliance_Log__c
            WHERE Household__c = :householdId
            AND Log_Type__c IN :requiredLogTypes
            AND CreatedDate >= :cutoffDate
            WITH SECURITY_ENFORCED
        ];

        // Mark found types as true
        for (Compliance_Log__c log : existingLogs) {
            results.put(log.Log_Type__c, true);
        }

        return results;
    }
}
