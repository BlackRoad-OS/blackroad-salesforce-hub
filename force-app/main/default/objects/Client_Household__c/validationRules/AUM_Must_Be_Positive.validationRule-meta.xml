<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>AUM_Must_Be_Positive</fullName>
    <active>true</active>
    <description>Total AUM cannot be negative</description>
    <errorConditionFormula>Total_AUM__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Total_AUM__c</errorDisplayField>
    <errorMessage>Total AUM cannot be negative. Please enter a valid amount.</errorMessage>
</ValidationRule>
